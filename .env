# ─── LLM Configuration ─────────────────────────────────────────────
# Default: Ollama running locally. Install from https://ollama.com
# Then pull the model: ollama pull mistral-small

# Ollama API base (default)
OLLAMA_API_BASE=http://localhost:11434

# Alternative: HuggingFace Inference API (uncomment)
# HUGGINGFACE_API_KEY=your_hf_token_here

# Alternative: Local vLLM (uncomment)
# OPENAI_API_BASE=http://localhost:8000/v1
# OPENAI_API_KEY=dummy

# ─── Model Selection ──────────────────────────────────────────────
# Ollama model name — examples:
#   mistral-small                 (24B, best structured output, slow on 4GB VRAM)
#   phi4-mini                     (3.8B, fast, fits in GPU, good for extraction)
#   qwen3:8b                      (8B, balanced speed/quality)
#   gemma3:4b                     (4B, very fast)
EXTRACTION_MODEL=mistral-small
