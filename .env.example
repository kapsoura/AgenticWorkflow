# ─── LLM Configuration ─────────────────────────────────────────────
# Default: Ollama running locally. Install from https://ollama.com
# Then pull the model: ollama pull mistral-small

# Ollama API base (default)
OLLAMA_API_BASE=http://localhost:11434

# Alternative: HuggingFace Inference API (uncomment)
# HUGGINGFACE_API_KEY=your_hf_token_here

# Alternative: Local vLLM (uncomment)
# OPENAI_API_BASE=http://localhost:8000/v1
# OPENAI_API_KEY=dummy

# ─── Model Selection ──────────────────────────────────────────────
# litellm model string — examples:
#   ollama/mistral-small          (default — 24B, great structured output)
#   ollama/qwen3:32b              (stronger reasoning)
#   ollama/phi4:14b               (smallest viable option)
#   huggingface/mistralai/Mistral-Small-3.1-24B-Instruct-2503
EXTRACTION_MODEL=ollama/mistral-small

# ─── Anthropic / Report Generation Agent ──────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
API_HOST=127.0.0.1
API_PORT=8000

# ─── Claude Code CLI backend (used by all LLM agents) ─────────────
# Agents route LLM calls through the claude CLI instead of the API.
# Set CLAUDE_CLI_PATH to the absolute path of the `claude` binary.
# Find it with: which claude (macOS/Linux) or (Get-Command claude).Source (Windows)
# Without this set, all agents fall back to deterministic rule-based output.
CLAUDE_CLI_PATH=
ANTHROPIC_MODEL_NAME=haiku

# ─── LangSmith observability (optional) ───────────────────────────
# Free key at https://smith.langchain.com . Leave LANGCHAIN_TRACING_V2
# unset/false to keep tracing off; local logs/<trace_id>.jsonl always works.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=regulatory-signal-intelligence
